    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "express-xss-sanitizer": "^2.0.2",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
